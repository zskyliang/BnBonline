{
  "name": "bnb",
  "version": "1.0.0",
  "description": "H5泡泡堂在线版",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "collect:bc": "node scripts/collect-dodge-dataset.js",
    "collect:iql": "node scripts/collect-dodge-dataset.js --dataset-path=output/ml/datasets/dodge_iql_v1_mixed_200k.jsonl --report-path=output/ml/reports/dodge_iql_v1_collect_stats.json --screenshot-path=output/ml/reports/dodge_iql_v1_collect_final.png --policy-mode=pure --iql-mix=1 --mix-expert-ratio=0.6 --mix-random-ratio=0.2 --mix-epsilon-ratio=0.2 --quota-enabled=0",
    "eval:ml": "node scripts/eval-ml-dodge.js",
    "eval:iql": "node scripts/eval-ml-dodge.js --model-url=/output/ml/models/dodge_iql_v1.onnx --policy-mode=pure",
    "eval:combat:1v1": "node scripts/eval-combat-1v1.js",
    "train:bc:v1_1": "node scripts/train-bc-iterative.js",
    "train:iql": "python3 ml/train_iql.py --dataset output/ml/datasets/dodge_iql_v1_mixed_200k.jsonl --out-pt output/ml/models/dodge_iql_v1.pt --out-onnx output/ml/models/dodge_iql_v1.onnx --out-metrics output/ml/reports/iql_v1_metrics.json",
    "train:iql:iterative": "node scripts/train-iql-iterative.js",
    "train:combat:phase0": "node scripts/train-combat-phase0-incremental.js",
    "sprint:99": "node scripts/run-99-sprint.js"
  },
  "author": "SineYuan",
  "license": "ISC",
  "dependencies": {
    "body-parser": "^1.14.2",
    "express": "^4.13.4",
    "socket.io": "^1.4.5",
    "swig": "^1.4.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SineYuan/BnBonline.git"
  },
  "bugs": {
    "url": "https://github.com/SineYuan/BnBonline/issues"
  },
  "homepage": "https://github.com/SineYuan/BnBonline#readme"
}
